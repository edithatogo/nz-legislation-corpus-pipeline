{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/nz-legislation-record.schema.json",
  "title": "NZ Legislation Corpus Record",
  "type": "object",
  "required": [
    "stable_id",
    "record_schema_version",
    "work_id",
    "version_id",
    "title",
    "jurisdiction",
    "country",
    "source",
    "source_url",
    "api_url",
    "legislation_type",
    "legislation_status",
    "scrape_date",
    "ingest_timestamp_utc",
    "language",
    "text",
    "text_sha256",
    "source_hash",
    "pipeline_version"
  ],
  "properties": {
    "record_schema_version": {"const": "1.0"},
    "stable_id": {"type": "string", "minLength": 1},
    "work_id": {"type": "string"},
    "version_id": {"type": "string"},
    "title": {"type": "string"},
    "jurisdiction": {"const": "New Zealand"},
    "country": {"const": "NZ"},
    "source": {"type": "string"},
    "source_url": {"type": "string"},
    "api_url": {"type": "string"},
    "xml_url": {"type": "string"},
    "html_url": {"type": "string"},
    "pdf_url": {"type": "string"},
    "legislation_type": {"type": "string"},
    "legislation_subtype": {"type": "string"},
    "legislation_status": {"type": "string"},
    "version_date": {"type": "string"},
    "year": {"type": ["integer", "null"]},
    "scrape_date": {"type": "string"},
    "ingest_timestamp_utc": {"type": "string"},
    "administering_agencies": {"type": "array", "items": {"type": "string"}},
    "is_latest_version": {"type": "boolean"},
    "language": {"type": "string"},
    "text": {"type": "string"},
    "raw_xml_sha256": {"type": "string"},
    "raw_content_sha256": {"type": "string"},
    "text_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "pipeline_version": {"type": "string"},
    "id_is_ephemeral": {"type": "boolean"},
    "id_ephemeral_reason": {"type": "string"},
    "raw_version_metadata": {"type": "object"}
  },
  "additionalProperties": true
}
