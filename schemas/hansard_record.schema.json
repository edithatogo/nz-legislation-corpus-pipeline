{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/nz-hansard-record.schema.json",
  "title": "NZ Hansard Corpus Record",
  "type": "object",
  "required": [
    "stable_id",
    "jurisdiction",
    "country",
    "source",
    "source_archive",
    "source_file",
    "source_row_number",
    "parliament_number",
    "parliament_document_id",
    "document_type",
    "title",
    "content",
    "language",
    "text_sha256",
    "source_hash",
    "pipeline_version"
  ],
  "properties": {
    "stable_id": {"type": "string", "minLength": 1},
    "jurisdiction": {"const": "New Zealand"},
    "country": {"const": "NZ"},
    "source": {"type": "string", "minLength": 1},
    "source_archive": {"type": "string", "minLength": 1},
    "source_file": {"type": "string", "minLength": 1},
    "source_row_number": {"type": "integer", "minimum": 1},
    "parliament_number": {"type": "integer"},
    "parliament_document_id": {"type": "string", "minLength": 1},
    "document_type": {"type": "string"},
    "title": {"type": "string"},
    "abbreviated_title": {"type": ["string", "null"]},
    "status": {"type": ["string", "null"]},
    "content": {"type": "string", "minLength": 1},
    "member_of_parliament_raw": {"type": ["string", "null"]},
    "member_of_parliament_count": {"type": "integer", "minimum": 0},
    "portfolio_raw": {"type": ["string", "null"]},
    "last_modified": {"type": ["string", "null"]},
    "document_content_date": {"type": ["string", "null"]},
    "language": {"type": "string", "minLength": 1},
    "text_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "pipeline_version": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
