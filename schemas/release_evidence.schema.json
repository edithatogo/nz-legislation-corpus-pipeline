{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/nz-legislation-release-evidence.schema.json",
  "title": "NZ Legislation Release Evidence",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_class",
    "generated_at_utc",
    "corpus_family_label",
    "sibling_corpus",
    "publication_target",
    "coverage_statement",
    "source_commit_sha",
    "workflow",
    "dataset",
    "manifest",
    "subjects",
    "attestation_policy"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_class": {"type": "string", "minLength": 1},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "corpus_family_label": {"const": "corpus-nz-legislation"},
    "sibling_corpus": {"const": "corpus-nz-hansard"},
    "publication_target": {"type": "string", "minLength": 1},
    "coverage_statement": {"type": "string", "minLength": 1},
    "source_repository": {"type": "string"},
    "source_commit_sha": {"type": "string", "minLength": 1},
    "workflow": {
      "type": "object",
      "required": ["name", "run_id", "run_attempt", "ref", "event_name"],
      "properties": {
        "name": {"type": "string"},
        "run_id": {"type": "string"},
        "run_attempt": {"type": "string"},
        "ref": {"type": "string"},
        "event_name": {"type": "string"}
      },
      "additionalProperties": false
    },
    "dataset": {
      "type": "object",
      "required": ["huggingface_repo_id", "huggingface_revision", "zenodo_doi", "zenodo_concept_doi"],
      "properties": {
        "huggingface_repo_id": {"type": "string"},
        "huggingface_revision": {"type": "string"},
        "zenodo_doi": {"type": "string"},
        "zenodo_concept_doi": {"type": "string"}
      },
      "additionalProperties": false
    },
    "manifest": {
      "type": "object",
      "required": [
        "manifest_sha256",
        "content_sha256",
        "schema_version",
        "record_schema_version",
        "record_count"
      ],
      "properties": {
        "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "schema_version": {"type": "string"},
        "record_schema_version": {"type": "string"},
        "record_count": {"type": ["integer", "null"]}
      },
      "additionalProperties": false
    },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    },
    "attestation_policy": {
      "type": "object",
      "required": [
        "github_artifact_attestation",
        "signed_checksums",
        "slsa_style_provenance"
      ],
      "properties": {
        "github_artifact_attestation": {"type": "string", "minLength": 1},
        "signed_checksums": {"type": "string", "minLength": 1},
        "slsa_style_provenance": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
