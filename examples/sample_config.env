# Copy to .env for local runs. Do not commit real secrets.
NZ_LEGISLATION_API_KEY=replace_me
HF_TOKEN=replace_me
HF_REPO_ID=your-username/nz-legislation-corpus
ZENODO_TOKEN=replace_me
ZENODO_API_URL=https://sandbox.zenodo.org/api
ZENODO_DEPOSITION_ID=
ARCHIVE_CREATORS_JSON=[{"name":"Your Name","affiliation":"Your Institution"}]
ARCHIVE_LICENSE=cc-by-4.0
NZLC_SEARCH_TERMS=law,act,regulation,order
NZLC_SEARCH_FIELD=title
NZLC_SEARCH_SORT_BY=most_recently_updated
NZLC_LEGISLATION_TYPES=act,bill,secondary_legislation,amendment_paper
# Optional: in_force, not_in_force, no_value
NZLC_LEGISLATION_STATUS=
# Optional: Parliamentary Counsel Office or Agency
NZLC_PUBLISHER=
NZLC_OUTPUT_DIR=data
